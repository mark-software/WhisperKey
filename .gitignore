# ========================
# Xcode
# ========================

# User-specific settings
*.xcuserstate
xcuserdata/

# Xcode workspace schemes (keep shared schemes, ignore personal)
!*.xcodeproj/xcshareddata/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/

# Build products
build/
DerivedData/
*.o
*.hmap
*.ipa
*.dSYM
*.dSYM.zip

# Instruments
*.trace

# Archives
*.xcarchive

# Playgrounds
timeline.xctimeline
playground.xcworkspace

# ========================
# Swift Package Manager
# ========================
.build/
.swiftpm/
*.resolved

# Keep Package.resolved for reproducible builds (comment out if preferred)
# Package.resolved

# ========================
# CocoaPods (if ever added)
# ========================
Pods/
*.xcworkspace
!default.xcworkspace

# ========================
# Carthage (if ever added)
# ========================
Carthage/Build/
Carthage/Checkouts/

